# Test: process execution
# proc.sh is portable (sh -c on unix, cmd /C on windows); proc.run needs a
# real executable, so its record shape is covered by Go tests per-OS.
# Expected output:
# hello
# hello world

main : () -> <io, exn> () =
  let out = proc.sh("echo hello")
  let _ = print(trim(out))

  let out2 = proc.sh("echo hello world")
  print(trim(out2))
