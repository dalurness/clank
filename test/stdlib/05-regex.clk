# Test: regex operations — comprehensive
# Expected output:
# true
# false
# [123, 456]
# []
# hello world
# hello_world
# [a, b, c]
# [hello]
# [2026-07-17 10:00, 2026-07-17, 10:00]
# []
# ERROR at 10:00 — disk full
# key=a val=1
# key=b val=2
# true

parse-entry : (line: Str) -> <> Str =
  match rx.groups(line, "^(\\w+) \\[([0-9:]+)\\] (.*)$") {
    [_, level, ts, msg] => "${level} at ${ts} — ${msg}"
    _ => "unparsed"
  }

main : () -> <io> () =
  # Match
  let _ = print(show(rx.ok("hello", "^h.*o$")))
  let _ = print(show(rx.ok("hello", "^xyz")))

  # Find all matches
  let _ = print(show(rx.find("abc123def456", "[0-9]+")))

  # Find with no matches returns empty list
  let _ = print(show(rx.find("hello", "xyz")))

  # Replace
  let _ = print(rx.replace("hello_world", "_", " "))

  # Replace with no matches returns unchanged string
  let _ = print(rx.replace("hello_world", "xyz", "abc"))

  # Split
  let _ = print(show(rx.split("a,b,c", ",")))

  # Split with no matches returns single-element list
  let _ = print(show(rx.split("hello", ",")))

  # Capture groups: first match, [whole, g1, g2, ...]
  let _ = print(show(rx.groups("on 2026-07-17 10:00", "([0-9-]+) ([0-9:]+)")))

  # No match returns empty list
  let _ = print(show(rx.groups("hello", "([0-9]+)")))

  # Destructure groups with a list pattern
  let _ = print(parse-entry("ERROR [10:00] disk full"))

  # All matches with groups
  let kvs = rx.groups-all("a=1 b=2", "(\\w+)=(\\w+)")
  let _ = for kv in kvs do
    match kv {
      [_, k, v] => print("key=${k} val=${v}")
      _ => print("?")
    }

  # Case-insensitive via (?i) flag
  print(show(rx.ok("Hello", "(?i)^hello$")))
