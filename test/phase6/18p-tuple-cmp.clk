# Test: cmp dispatch on tuple type
# Expected output:
# equal
# less
# greater

main : () -> <io> () =
  match cmp((1, "a"), (1, "a")) {
    Lt => print("less")
    Gt => print("greater")
    Eq_ => print("equal")
  }
  match cmp((1, "a"), (1, "b")) {
    Lt => print("less")
    Gt => print("greater")
    Eq_ => print("equal")
  }
  match cmp((2, "x"), (1, "z")) {
    Lt => print("less")
    Gt => print("greater")
    Eq_ => print("equal")
  }
