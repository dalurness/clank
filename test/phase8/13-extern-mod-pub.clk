# Test: extern mod block with pub members
# Verifies pub prefix on individual members inside extern mod

extern mod "node:path" where host = "js" {
  pub basename : (path: Str) -> <io> Str
  pub join-path : (a: Str, b: Str) -> <io> Str
    where symbol = "join"
}

main : () -> <io> () =
  print(basename("/a/b/c.txt"))
  print(join-path("hello", "world"))

# Expected output:
# c.txt
# hello/world
