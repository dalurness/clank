# Spec example 8.7: Sum type and pattern matching
# Expected output:
# 78.53975
# 12

type Shape
  = Circle(Rat)
  | Rect(Rat, Rat)

area : (s: Shape) -> <> Rat =
  match s {
    Circle(r) => r * r * 3.14159
    Rect(w, h) => w * h
  }

main : () -> <io> () =
  print(show(area(Circle(5.0))))
  print(show(area(Rect(3.0, 4.0))))
