# Spec example 8.9: Effectful pipeline with do-block
# Demonstrates do-block sequencing pattern from the spec:
#   do { contents <- read(src); write(dst, contents); print(...) }
# Adapted to use string processing instead of file I/O
# Expected output:
# Processed: hello world (length: 11)

process : (input: Str) -> <io> () = do {
  contents <- input
  length <- len(split(contents, ""))
  print("Processed: " ++ contents ++ " (length: " ++ show(length) ++ ")")
}

main : () -> <io> () =
  process("hello world")
