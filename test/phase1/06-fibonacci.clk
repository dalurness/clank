# Test: recursive fibonacci function
# Expected output:
# 0
# 1
# 1
# 5
# 55

fib : (n: Int) -> <> Int =
  if n == 0 then 0
  else if n == 1 then 1
  else fib(n - 1) + fib(n - 2)

main : () -> <io> () =
  print(show(fib(0)))
  print(show(fib(1)))
  print(show(fib(2)))
  print(show(fib(5)))
  print(show(fib(10)))
