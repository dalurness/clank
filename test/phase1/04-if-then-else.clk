# Test: if/then/else expressions
# Expected output:
# yes
# 1
# negative
# zero

main : () -> <io> () =
  print(if true then "yes" else "no")
  print(show(if 5 > 3 then 1 else 0))
  let x = -5
  print(if x > 0 then "positive" else if x == 0 then "zero" else "negative")
  print(if 0 == 0 then "zero" else "nonzero")
