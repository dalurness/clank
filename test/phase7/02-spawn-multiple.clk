# Test: spawn multiple tasks and await all
# Verifies that multiple independent tasks can be spawned and awaited

main : () -> <io, async> () =
  let f1 = spawn(fn() => 10)
  let f2 = spawn(fn() => 20)
  let f3 = spawn(fn() => 30)
  let r1 = await(f1)
  let r2 = await(f2)
  let r3 = await(f3)
  print(show(add(r1, add(r2, r3))))

# Expected output:
# 60
