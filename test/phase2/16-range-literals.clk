# Test: range literal syntax (.. and ..=)
# Expected output:
# [1, 2, 3, 4]
# [1, 2, 3, 4, 5]
# []
# []
# [-1, 0, 1, 2]
# 55
# [2, 4]
# [1, 4, 9, 16]
# 5
# [(1, 1), (1, 2), (2, 1), (2, 2)]

main : () -> <io> () =
  # half-open range: 1..5 yields [1, 2, 3, 4]
  print(show(1..5))

  # inclusive range: 1..=5 yields [1, 2, 3, 4, 5]
  print(show(1..=5))

  # empty half-open range: 5..3
  print(show(5..3))

  # empty inclusive range: 5..=4
  print(show(5..=4))

  # negative bounds
  print(show(-1..3))

  # range with fold: sum 1..=10
  print(show(for i in 1..=10 fold t = 0 do t + i))

  # range in pipeline
  print(show(1..5 |> filter(fn(x) => x % 2 == 0)))

  # range with map
  print(show(for x in 1..=4 do x * x))

  # range with let binding
  let xs = 0..5
  print(show(len(xs)))

  # nested ranges
  print(show(flat-map(1..=2, fn(i) => for j in 1..=2 do (i, j))))
