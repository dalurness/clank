# Test: match with literal, wildcard, and variable patterns
# Expected output:
# zero
# one
# other: 5
# found true

main : () -> <io> () =
  let x = 0
  match x {
    0 => print("zero")
    1 => print("one")
    n => print("other: " ++ show(n))
  }
  let y = 1
  match y {
    0 => print("zero")
    1 => print("one")
    n => print("other: " ++ show(n))
  }
  let z = 5
  match z {
    0 => print("zero")
    1 => print("one")
    n => print("other: " ++ show(n))
  }
  let b = true
  match b {
    true => print("found true")
    false => print("found false")
  }
